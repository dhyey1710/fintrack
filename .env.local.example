# ============================================================
# FinTrack — Environment Variables Template
# ============================================================
# 1. Copy this file:  cp .env.local.example .env.local
# 2. Fill in your credentials below
# 3. Never commit .env.local to git (it's already in .gitignore)
# ============================================================

# Firebase Configuration
# Get these from: https://console.firebase.google.com/ → Project Settings → Your Apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Gemini AI (for Smart Quick Add feature)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# [START Firebase Admin SDK Config]
# Required for verifying users on the backend (e.g. AI Smart Add)
# Go to: Firebase Console -> Project Settings -> Service Accounts -> "Generate new private key"
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# [END Firebase Admin SDK Config]
